# =============================================================================
# JS7 JobScheduler deployment configuration
# -----------------------------------------------------------------------------
# Copy this file to "config.env" and edit the values for your environment:
#
#     cp deploy/config.env.example deploy/config.env
#     nano deploy/config.env
#
# config.env is git-ignored because it holds secrets. NEVER commit it.
# All scripts in deploy/ source this file.
# =============================================================================

# --- Web / TLS -------------------------------------------------------------
# Fully-qualified subdomain that will serve the JOC Cockpit web UI.
# You MUST create a DNS A record pointing this name at the VPS public IP
# BEFORE running 06-nginx-tls.sh (Let's Encrypt validates over HTTP).
DOMAIN="scheduler.example.com"

# Email passed to certbot for Let's Encrypt expiry notices.
LETSENCRYPT_EMAIL="admin@example.com"

# Set to "true" to use the Let's Encrypt staging environment (untrusted certs,
# high rate limits) while testing, then switch back to "false" for real certs.
LETSENCRYPT_STAGING="false"

# --- JS7 versions ----------------------------------------------------------
# Pin the JS7 release to install. Use a current LTS release.
# Verify the latest at: https://sourceforge.net/projects/jobscheduler/files/
# (e.g. 2.7.x or 2.8.x). All three components must use the SAME version.
JS7_VERSION="2.7.8"

# MySQL Connector/J (JDBC driver) version. JS7 does not bundle it.
# Verify at: https://dev.mysql.com/downloads/connector/j/
MYSQL_CONNECTOR_VERSION="8.4.0"

# --- Download sources ------------------------------------------------------
# JS7 release artifacts live on SourceForge. The scripts build URLs as:
#   ${JS7_DOWNLOAD_BASE}/${JS7_VERSION}/<filename>/download
# IMPORTANT: filenames occasionally change between releases. If a download
# 404s, open the files page below, copy the exact names, and update the
# *_ARCHIVE patterns. ${VER} is replaced with JS7_VERSION.
#   https://sourceforge.net/projects/jobscheduler/files/JobScheduler.2/
JS7_DOWNLOAD_BASE="https://sourceforge.net/projects/jobscheduler/files/JobScheduler.2"
JOC_ARCHIVE="js7_joc_linux.\${VER}.tar.gz"
CONTROLLER_ARCHIVE="js7_controller_unix.\${VER}.tar.gz"
AGENT_ARCHIVE="js7_agent_unix.\${VER}.tar.gz"

# MySQL Connector/J download (Maven Central is stable and scriptable).
MYSQL_CONNECTOR_URL="https://repo1.maven.org/maven2/com/mysql/mysql-connector-j/\${MYSQL_CONNECTOR_VERSION}/mysql-connector-j-\${MYSQL_CONNECTOR_VERSION}.jar"

# --- OS user / install paths ----------------------------------------------
# Dedicated unprivileged OS user that owns and runs the JS7 processes.
JS7_USER="jobscheduler"
JS7_GROUP="jobscheduler"

# Base directory for binaries and data. Each component gets a subdirectory.
JS7_HOME="/opt/sos-berlin.com/js7"

# --- Network ports (all bound to localhost; nginx is the only public entry) -
JOC_HTTP_PORT="4446"          # JOC Cockpit web UI (proxied by nginx)
CONTROLLER_HTTP_PORT="4444"   # Controller API
AGENT_HTTP_PORT="4445"        # Agent API

# Logical IDs for the cluster objects.
CONTROLLER_ID="controller"
AGENT_ID="agent"

# --- Database (MySQL) ------------------------------------------------------
DB_HOST="127.0.0.1"
DB_PORT="3306"
DB_NAME="scheduler"
DB_USER="jobscheduler"
# CHANGE THIS. Used to create the MySQL user and in the JOC hibernate config.
DB_PASSWORD="CHANGE_ME_strong_db_password"
# MySQL root password set during 02-install-mysql.sh (used only locally).
DB_ROOT_PASSWORD="CHANGE_ME_strong_root_password"

# --- Misc ------------------------------------------------------------------
# Server timezone (see: timedatectl list-timezones).
TIMEZONE="UTC"
