// JoineryFlow data model.
// SQLite keeps deployment on a Hostinger VPS dead simple (single file, no server).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// The single owner account. Holds Google OAuth tokens once connected.
model Account {
  id              String   @id @default(cuid())
  email           String   @unique
  name            String?
  phone           String?  // business phone — usable in email templates as {{businessPhone}}
  // App login password (scrypt hash). When set, it overrides APP_PASSWORD and is
  // what the owner changes from Settings → Password.
  passwordHash    String?
  // Google OAuth — null until the owner connects their Google account.
  googleAccessToken  String?
  googleRefreshToken String?
  googleTokenExpiry  DateTime?
  googleEmail        String?
  calendarId         String   @default("primary")
  driveFolderId      String?  // root Drive folder where job PDFs are filed
  signature          String?  // appended to client emails
  logo               String?  // base64 primary logo (dashboard light, emails, reports)
  logoMime           String?  // mime type of the logo (e.g. image/png)
  logoDark           String?  // base64 optional dark-mode logo for the dashboard
  logoDarkMime       String?  // mime type of the dark-mode logo
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Client {
  id        String   @id @default(cuid())
  name      String
  email     String?
  phone     String?
  address   String?
  notes     String?
  jobs      Job[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Job lifecycle: lead -> quoted -> accepted -> scheduled -> in_progress -> completed
//                                         \-> cancelled (from any state)
model Job {
  id           String    @id @default(cuid())
  reference    String    @unique          // human reference e.g. JOB-1042
  title        String
  description  String?
  status       String    @default("lead") // see lifecycle above
  priority     String    @default("normal") // low | normal | high

  // Scheduling
  scheduledStart DateTime?
  scheduledEnd   DateTime?
  durationMins   Int       @default(120)

  // Money
  quoteAmount  Float?
  currency     String   @default("AUD")

  // Site
  address      String?

  // Client (denormalised contact kept for quick edits / leads without a saved client)
  clientId     String?
  client       Client?  @relation(fields: [clientId], references: [id])
  clientName   String?
  clientEmail  String?
  clientPhone  String?

  // The joinery company this job is for (the "client"). Set when imported from
  // a trusted sender, or chosen on the New-job form. References LeadSource.id.
  companyId      String?

  // Lead provenance — set when a job was imported from an incoming email.
  leadSource     String?  // sender email address it came from
  gmailMessageId String?  // source email (shared by all jobs split from one email)
  gmailThreadId  String?

  // Review flag set by intake reconciliation (e.g. "review" = the job's company
  // sent a weekly email that no longer lists it — possibly moved/cancelled).
  flag           String?
  // How many distinct company emails in a row have omitted this job, plus the id
  // of the last email counted (so re-scanning the same email doesn't double-count).
  // Two misses on a job that's on Google Calendar → assume cancelled & soft-delete.
  reviewMisses    Int     @default(0)
  reviewMessageId String?

  // Google links
  googleEventId  String?  // primary calendar event (first working day)
  googleEventIds String?  // JSON array of all calendar event ids (one per working day)
  driveFolderId  String?  // Drive folder for this job's PDFs
  drivePhotosFolderId String? // shared "Photos (client)" subfolder (anyone-with-link)

  documents    Document[]
  reports      MaintenanceReport[]
  activities   Activity[]

  notes        String?
  deletedAt    DateTime? // soft delete — hidden from lists, restorable for 30 days
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// A PDF (or other file) saved from email into Google Drive, linked to a job.
model Document {
  id          String   @id @default(cuid())
  jobId       String
  job         Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  name        String
  driveFileId String?
  webViewLink String?
  source      String   @default("gmail") // gmail | upload | report
  mimeType    String   @default("application/pdf")
  createdAt   DateTime @default(now())
}

model MaintenanceReport {
  id          String   @id @default(cuid())
  jobId       String
  job         Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  status      String   @default("draft") // draft | sent
  // Free-form report fields stored as JSON (engineer, findings, actions, recommendations, etc.)
  data        String   @default("{}")
  pdfPath     String?
  driveFileId String?
  webViewLink String?
  sentAt      DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Audit trail surfaced in the UI: what automations ran for a job.
model Activity {
  id        String   @id @default(cuid())
  jobId     String?
  job       Job?     @relation(fields: [jobId], references: [id], onDelete: Cascade)
  type      String   // status_change | calendar | drive | email | report | note
  message   String
  meta      String   @default("{}")
  createdAt DateTime @default(now())
}

// Record of every lead email we've already scanned (even if it produced no
// jobs), so non-job emails aren't reprocessed (and re-charged) every scan.
model ProcessedEmail {
  id          String   @id @default(cuid())
  messageId   String   @unique
  jobsCreated Int      @default(0)
  reason      String?  // e.g. "maintenance", "no_new_jobs"
  createdAt   DateTime @default(now())
}

// Trusted senders whose emails are turned into job leads to approve.
// A joinery company the owner works for — these are the app's "clients".
model LeadSource {
  id          String   @id @default(cuid())
  name        String
  displayName String?  // client-facing name when it differs (e.g. "A&Z (via Ingenuity)")
  email       String   @unique
  enabled     Boolean  @default(true)
  templates   String?  // JSON: per-company email overrides keyed by accepted|moved|cancelled
  createdAt   DateTime @default(now())
}

// Web Push subscriptions (one per device that opted in to notifications).
model PushSubscription {
  id        String   @id @default(cuid())
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
}

// Editable templates for the automated client emails.
model EmailTemplate {
  id        String   @id @default(cuid())
  key       String   @unique // accepted | cancelled | moved | report
  subject   String
  body      String
  enabled   Boolean  @default(true)
  updatedAt DateTime @updatedAt
}
