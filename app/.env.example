# ---- JoineryFlow configuration ----
# Copy to .env and fill in. .env is git-ignored.

# SQLite database file (relative paths are resolved from the prisma/ dir).
DATABASE_URL="file:./joineryflow.db"

# Public base URL of the app (used to build the Google OAuth redirect URI).
# Local dev: http://localhost:3000   Production: https://jobs.yourdomain.com
APP_URL="http://localhost:3000"

# White-label app name (PWA / home-screen / browser title). The in-app header and
# login also show your business Name + logo from Settings. Defaults to JoineryFlow.
APP_NAME="JoineryFlow"

# The owner's email — the single user who logs in / owns all jobs.
OWNER_EMAIL="you@example.com"

# ---- Google OAuth ----
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorised redirect URI must be: ${APP_URL}/api/auth/google/callback
# Enable these APIs: Google Calendar, Google Drive, Gmail.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Optional: a simple shared password to gate the dashboard (single-user app).
# Leave blank to disable the login gate (fine behind a private URL / VPN).
APP_PASSWORD=""

# Secret used to sign the session cookie. Generate with: openssl rand -hex 32
SESSION_SECRET="change-me-to-a-long-random-string"

# Shared secret for the automated inbox scan (cron). Generate with: openssl rand -hex 32
# Used by deploy/setup-cron.sh to let the scheduled task import new job leads.
CRON_SECRET=""

# ---- AI image reading (Anthropic Claude vision) ----
# Reads PNG/JPG job sheets from incoming emails and extracts the job details.
# Get a key at https://console.anthropic.com/ . Leave blank to disable (images
# are still saved to Drive, just not auto-read). ~1-3 cents per image.
ANTHROPIC_API_KEY=""
# Optional model override (defaults to the recommended claude-opus-4-8).
ANTHROPIC_MODEL=""

# ---- Push notifications (optional) ----
# Pings your phone when the inbox check finds new jobs to confirm / flags one.
# Generate a key pair once with:  npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
# Contact URI for the push service (any mailto: you control).
VAPID_SUBJECT="mailto:you@example.com"

# ---- Scheduling / timezone ----
# Business timezone for calendar events. Jobs run 6:30am–3:00pm in this zone;
# multi-day jobs spill onto the following working days (weekends skipped).
BUSINESS_TZ="Australia/Sydney"
# Also set the process timezone so stored times line up with the business zone.
TZ="Australia/Sydney"
